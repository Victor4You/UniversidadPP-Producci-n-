// src/components/test/CourseTestModal.tsx
"use client";

import { Fragment, useState, useEffect, useCallback } from "react";
import { Dialog, Transition } from "@headlessui/react";
import axios from "axios";
import { useAuth } from "@/hooks/useAuth";

// --- ICONOS ---
const XMarkIcon = () => (
  <svg className="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
  </svg>
);
const PlayIcon = () => (
  <svg className="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
);
const FileIcon = () => (
  <svg className="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
  </svg>
);
const LockIcon = () => (
  <svg className="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
  </svg>
);

export default function CourseTestModal({ isOpen, onClose, course, enrollmentStatus, onExamSuccess }: any) {
  const { user } = useAuth();
  
  const [showExam, setShowExam] = useState(false);
  const [currentVideo, setCurrentVideo] = useState<any>(null);
  const [currentPDF, setCurrentPDF] = useState<any>(null);
  const [watchedVideos, setWatchedVideos] = useState<string[]>([]);
  const [readPDFs, setReadPDFs] = useState<string[]>([]);
  const [canTakeExam, setCanTakeExam] = useState(false);
  const [pdfScrollReached, setPdfScrollReached] = useState(false);

  // Estados del Examen
  const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);
  const [answers, setAnswers] = useState<any>({});
  const [timeLeft, setTimeLeft] = useState(0);
  const [isSubmitting, setIsSubmitting] = useState(false);

  useEffect(() => {
    if (isOpen && course) {
      setShowExam(false);
      setCurrentQuestionIndex(0);
      setAnswers({});
      const savedProgress = localStorage.getItem(`course_progress_${course.id}_${user?.id}`);
      if (savedProgress) {
        const { watched, read } = JSON.parse(savedProgress);
        setWatchedVideos(watched || []);
        setReadPDFs(read || []);
      }
    }
  }, [isOpen, course, user]);

  useEffect(() => {
    if (!course) return;
    if (course.tipo === 'in-person') {
      setCanTakeExam(true);
      return;
    }
    const allVideosWatched = course.videos?.every((v: any) => watchedVideos.includes(v.id)) ?? true;
    const allPDFsRead = course.pdfs?.every((p: any) => readPDFs.includes(p.id)) ?? true;
    
    if (course.tipo === 'specialized') {
      const allSectionsDone = course.secciones?.every((sec: any) => {
        const vDone = sec.videos?.every((v: any) => watchedVideos.includes(v.id)) ?? true;
        const pDone = sec.pdfs?.every((p: any) => readPDFs.includes(p.id)) ?? true;
        return vDone && pDone;
      }) ?? true;
      setCanTakeExam(allSectionsDone);
    } else {
      setCanTakeExam(allVideosWatched && allPDFsRead);
    }
  }, [watchedVideos, readPDFs, course]);

  // Timer del Examen
  useEffect(() => {
    let timer: any;
    if (showExam && timeLeft > 0) {
      timer = setInterval(() => setTimeLeft((prev) => prev - 1), 1000);
    } else if (showExam && timeLeft === 0) {
      handleSubmitExam();
    }
    return () => clearInterval(timer);
  }, [showExam, timeLeft]);

  const startExam = () => {
    // CORRECCIÓN: Buscamos duracionExamen o duracion, con 30 mins por defecto si no hay nada
    const duration = parseInt(course.duracionExamen) || parseInt(course.duracion) || 30; 
    setTimeLeft(duration * 60);
    setShowExam(true);
  };

  const saveProgress = (watched: string[], read: string[]) => {
    localStorage.setItem(`course_progress_${course.id}_${user?.id}`, JSON.stringify({ watched, read }));
  };

  const markVideoAsWatched = (videoId: string) => {
    if (!watchedVideos.includes(videoId)) {
      const newWatched = [...watchedVideos, videoId];
      setWatchedVideos(newWatched);
      saveProgress(newWatched, readPDFs);
    }
    setCurrentVideo(null);
  };

  const markPDFAsRead = () => {
    if (currentPDF && !readPDFs.includes(currentPDF.id)) {
      const newRead = [...readPDFs, currentPDF.id];
      setReadPDFs(newRead);
      saveProgress(watchedVideos, newRead);
    }
    setCurrentPDF(null);
    setPdfScrollReached(false);
  };

  const getFileUrl = (url: string) => {
    if (!url) return "";
    if (url.startsWith("http")) return url;
    return `http://194.113.64.53:3014${url}`;
  };

  const handleSubmitExam = async () => {
    if (isSubmitting) return;
    setIsSubmitting(true);
    try {
      const response = await axios.post('http://194.113.64.53:3014/v1/courses/register-completion', {
        userId: user?.id,
        courseId: course.id,
        respuestas: answers
      });
      if (onExamSuccess) onExamSuccess(response.data);
      onClose();
    } catch (error) {
      console.error("Error al enviar examen", error);
      alert("Hubo un problema al calificar tu examen.");
    } finally {
      setIsSubmitting(false);
    }
  };

  if (!isOpen || !course) return null;

  return (
    <Transition.Root show={isOpen} as={Fragment}>
      <Dialog as="div" className="relative z-[100]" onClose={onClose}>
        <Transition.Child as={Fragment} enter="ease-out duration-300" enterFrom="opacity-0" enterTo="opacity-100" leave="ease-in duration-200" leaveFrom="opacity-100" leaveTo="opacity-0">
          <div className="fixed inset-0 bg-black/80 backdrop-blur-xl" />
        </Transition.Child>

        <div className="fixed inset-0 z-10 overflow-y-auto">
          <div className="flex min-h-full items-center justify-center p-4">
            <Transition.Child as={Fragment} enter="ease-out duration-300" enterFrom="opacity-0 scale-95" enterTo="opacity-100 scale-100" leave="ease-in duration-200" leaveFrom="opacity-100 scale-100" leaveTo="opacity-0 scale-95">
              <Dialog.Panel className="relative w-full max-w-4xl bg-[#f8fafc] rounded-[40px] shadow-2xl overflow-hidden border border-white">
                
                {/* VISTA DE EXAMEN */}
                {showExam ? (
                  <div className="flex flex-col h-[80vh]">
                    <div className="p-8 bg-white border-b flex justify-between items-center">
                      <div>
                        <h2 className="text-2xl font-black uppercase tracking-tighter italic">Evaluación Final</h2>
                        <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                          Pregunta {currentQuestionIndex + 1} de {course.questions?.length || 0}
                        </p>
                      </div>
                      <div className="flex items-center gap-4">
                        <div className="text-right">
                          <p className="text-[9px] font-black text-slate-400 uppercase">Tiempo Restante</p>
                          <p className={`text-xl font-black ${timeLeft < 60 ? 'text-red-500 animate-pulse' : 'text-black'}`}>
                            {Math.floor(timeLeft / 60)}:{(timeLeft % 60).toString().padStart(2, '0')}
                          </p>
                        </div>
                      </div>
                    </div>

                    <div className="flex-1 overflow-y-auto p-12">
                      {/* CORRECCIÓN: course.questions en lugar de course.preguntas */}
                      {course.questions && course.questions[currentQuestionIndex] ? (
                        <div className="max-w-2xl mx-auto">
                          <h3 className="text-2xl font-black text-slate-900 mb-8 leading-tight uppercase">
                            {course.questions[currentQuestionIndex].question}
                          </h3>
                          <div className="space-y-3">
                            {course.questions[currentQuestionIndex].options?.map((opcion: string, i: number) => (
                              <button
                                key={i}
                                onClick={() => setAnswers({ ...answers, [currentQuestionIndex]: opcion })}
                                className={`w-full p-6 rounded-3xl text-left transition-all font-bold uppercase text-xs border-2 ${
                                  answers[currentQuestionIndex] === opcion 
                                  ? "border-blue-600 bg-blue-50 text-blue-700 shadow-lg" 
                                  : "border-slate-100 bg-white text-slate-500 hover:border-slate-300"
                                }`}
                              >
                                {opcion}
                              </button>
                            ))}
                          </div>
                        </div>
                      ) : (
                        <div className="text-center text-gray-500 mt-10 font-bold uppercase">
                          No hay preguntas configuradas para este examen.
                        </div>
                      )}
                    </div>

                    <div className="p-8 bg-white border-t flex justify-between items-center">
                      <button
                        disabled={currentQuestionIndex === 0}
                        onClick={() => setCurrentQuestionIndex(prev => prev - 1)}
                        className="px-8 py-4 text-[10px] font-black uppercase text-slate-400 disabled:opacity-0 hover:text-slate-600"
                      >
                        Anterior
                      </button>
                      {/* CORRECCIÓN: course.questions.length */}
                      {currentQuestionIndex === ((course.questions?.length || 1) - 1) ? (
                        <button
                          onClick={handleSubmitExam}
                          disabled={isSubmitting || !answers[currentQuestionIndex]}
                          className="px-12 py-4 bg-green-600 text-white rounded-2xl font-black text-[10px] uppercase shadow-xl hover:scale-105 transition-all disabled:bg-gray-300 disabled:shadow-none disabled:hover:scale-100"
                        >
                          {isSubmitting ? 'ENVIANDO...' : 'FINALIZAR Y CALIFICAR'}
                        </button>
                      ) : (
                        <button
                          disabled={!answers[currentQuestionIndex]}
                          onClick={() => setCurrentQuestionIndex(prev => prev + 1)}
                          className="px-12 py-4 bg-black text-white rounded-2xl font-black text-[10px] uppercase shadow-xl hover:scale-105 transition-all disabled:bg-gray-300 disabled:shadow-none disabled:hover:scale-100"
                        >
                          Siguiente Pregunta
                        </button>
                      )}
                    </div>
                  </div>
                ) : (
                  /* VISTA DE CONTENIDO (TU CÓDIGO ORIGINAL) */
                  <>
                    <div className="p-8 flex justify-between items-start bg-white border-b border-slate-100">
                      <div>
                        <div className="flex items-center gap-3 mb-2">
                          <span className="px-3 py-1 bg-blue-600 text-white text-[10px] font-black rounded-full uppercase tracking-widest">CURSO</span>
                          <span className="px-3 py-1 bg-slate-100 text-slate-500 text-[10px] font-black rounded-full uppercase tracking-widest">{course.categoria}</span>
                        </div>
                        <Dialog.Title className="text-3xl font-black text-slate-900 uppercase tracking-tighter leading-none">{course.nombre}</Dialog.Title>
                        <p className="text-slate-500 text-sm font-bold uppercase mt-2 tracking-tighter">Instructor: {course.profesor || 'Universidad'}</p>
                      </div>
                      <button onClick={onClose} className="p-3 bg-slate-100 hover:bg-red-50 text-slate-400 hover:text-red-500 rounded-2xl transition-all"><XMarkIcon /></button>
                    </div>

                    <div className="p-8">
                      {course.tipo === 'in-person' ? (
                        <div className="mb-8 p-10 bg-purple-50 rounded-[32px] border-2 border-dashed border-purple-200 text-center">
                          <div className="w-16 h-16 bg-purple-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-purple-200">
                            <svg className="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                          </div>
                          <h3 className="text-purple-900 font-black text-xl uppercase tracking-tighter">Asistencia Confirmada</h3>
                          <p className="text-purple-600 text-xs font-bold uppercase mt-2">Has completado la parte presencial. Puedes proceder directamente al examen.</p>
                        </div>
                      ) : (
                        <div className="mb-8">
                          <div className="flex items-center gap-2 mb-6">
                            <div className="h-2 w-2 bg-blue-600 rounded-full animate-pulse" />
                            <h3 className="text-xs font-black text-slate-400 uppercase tracking-[0.2em]">Contenido del Aprendizaje</h3>
                          </div>
                          <div className="space-y-4">
                            {course.tipo === 'specialized' ? (
                              course.secciones?.map((sec: any, idx: number) => (
                                <div key={idx} className="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
                                  <h4 className="text-sm font-black text-slate-900 uppercase mb-4 flex items-center gap-2">
                                    <span className="w-6 h-6 bg-slate-900 text-white text-[10px] rounded-lg flex items-center justify-center">{idx + 1}</span>
                                    {sec.titulo}
                                  </h4>
                                  <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                                    {sec.videos?.map((v: any) => (
                                      <button key={v.id} onClick={() => setCurrentVideo(v)} className={`flex items-center gap-4 p-4 rounded-2xl border transition-all ${watchedVideos.includes(v.id) ? "bg-green-50 border-green-100" : "bg-slate-50 border-slate-100 hover:bg-white hover:shadow-md"}`}>
                                        <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${watchedVideos.includes(v.id) ? "bg-green-500 text-white" : "bg-blue-600 text-white"}`}><PlayIcon /></div>
                                        <div className="text-left"><p className="text-[10px] font-black uppercase text-slate-900">{v.title}</p></div>
                                      </button>
                                    ))}
                                    {sec.pdfs?.map((p: any) => (
                                      <button key={p.id} onClick={() => { setCurrentPDF(p); setPdfScrollReached(false); }} className={`flex items-center gap-4 p-4 rounded-2xl border transition-all ${readPDFs.includes(p.id) ? "bg-green-50 border-green-100" : "bg-slate-50 border-slate-100 hover:bg-white hover:shadow-md"}`}>
                                        <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${readPDFs.includes(p.id) ? "bg-green-500 text-white" : "bg-orange-500 text-white"}`}><FileIcon /></div>
                                        <div className="text-left"><p className="text-[10px] font-black uppercase text-slate-900">{p.title}</p></div>
                                      </button>
                                    ))}
                                  </div>
                                </div>
                              ))
                            ) : (
                              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                {course.videos?.map((v: any) => (
                                  <button key={v.id} onClick={() => setCurrentVideo(v)} className={`flex items-center gap-4 p-5 rounded-[28px] border transition-all ${watchedVideos.includes(v.id) ? "bg-green-50 border-green-200" : "bg-white border-slate-100 hover:shadow-xl hover:scale-[1.02]"}`}>
                                    <div className={`w-12 h-12 rounded-2xl flex items-center justify-center shadow-lg ${watchedVideos.includes(v.id) ? "bg-green-500 text-white" : "bg-blue-600 text-white"}`}><PlayIcon /></div>
                                    <div className="text-left"><p className="text-xs font-black uppercase tracking-tight text-slate-900">{v.title}</p></div>
                                  </button>
                                ))}
                                {course.pdfs?.map((p: any) => (
                                  <button key={p.id} onClick={() => { setCurrentPDF(p); setPdfScrollReached(false); }} className={`flex items-center gap-4 p-5 rounded-[28px] border transition-all ${readPDFs.includes(p.id) ? "bg-green-50 border-green-200" : "bg-white border-slate-100 hover:shadow-xl hover:scale-[1.02]"}`}>
                                    <div className={`w-12 h-12 rounded-2xl flex items-center justify-center shadow-lg ${readPDFs.includes(p.id) ? "bg-green-500 text-white" : "bg-orange-500 text-white"}`}><FileIcon /></div>
                                    <div className="text-left"><p className="text-xs font-black uppercase tracking-tight text-slate-900">{p.title}</p></div>
                                  </button>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      )}

                      <div className="mt-12 pt-8 border-t border-slate-100">
                        <button
                          onClick={startExam}
                          disabled={!canTakeExam}
                          className={`w-full py-6 rounded-[32px] font-black text-xs tracking-[0.3em] uppercase transition-all duration-500 flex items-center justify-center gap-4 ${canTakeExam ? "bg-black text-white shadow-2xl shadow-black/20 hover:scale-[1.02] active:scale-95" : "bg-slate-100 text-slate-300 cursor-not-allowed"}`}
                        >
                          {canTakeExam ? <>COMENZAR EVALUACIÓN FINAL <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={3} d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></> : <>BLOQUEADO: FINALIZA EL CONTENIDO <LockIcon /></>}
                        </button>
                        <p className="text-center text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-6">AL INICIAR EL EXAMEN, SE REGISTRARÁ TU PRIMER INTENTO OFICIAL.</p>
                      </div>
                    </div>
                  </>
                )}

                {/* MODALES DE CONTENIDO */}
                {currentVideo && (
                  <div className="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/95 backdrop-blur-sm">
                    <div className="w-full max-w-5xl aspect-video bg-black rounded-3xl overflow-hidden relative shadow-2xl border border-white/10">
                      <iframe src={getFileUrl(currentVideo.fileUrl)} className="w-full h-full" allowFullScreen allow="autoplay" />
                      <button onClick={() => markVideoAsWatched(currentVideo.id)} className="absolute top-6 right-6 p-4 bg-white/10 hover:bg-white/20 text-white rounded-2xl backdrop-blur-md transition-all font-black text-[10px] uppercase tracking-widest">CERRAR Y MARCAR COMO VISTO</button>
                    </div>
                  </div>
                )}

                {currentPDF && (
                  <div className="fixed inset-0 z-[110] flex items-center justify-center p-6 bg-black/90">
                    <div className="w-full max-w-4xl h-full flex flex-col">
                      <div className="flex justify-between items-center mb-3 text-white"><h3 className="font-black text-xs uppercase">{currentPDF.title}</h3><button onClick={() => setCurrentPDF(null)} className="text-xs font-black uppercase hover:text-red-500">CERRAR LECTURA</button></div>
                      <div className="flex-1 bg-white rounded-xl overflow-hidden relative shadow-2xl">
                        <iframe src={`${getFileUrl(currentPDF.fileUrl)}#toolbar=0&navpanes=0`} className="w-full h-full border-none" />
                        <div onMouseEnter={() => setPdfScrollReached(true)} className="absolute bottom-0 left-0 w-full h-20 bg-gradient-to-t from-black/20 to-transparent pointer-events-auto" />
                      </div>
                      <div className="mt-4 flex flex-col items-center gap-2">
                        <button disabled={!pdfScrollReached} onClick={markPDFAsRead} className={`w-full py-4 rounded-2xl font-black uppercase transition-all duration-300 ${pdfScrollReached ? "bg-green-600 text-white shadow-lg scale-[1.02]" : "bg-gray-800 text-gray-500 cursor-not-allowed"}`}>
                          {pdfScrollReached ? "CONFIRMAR LECTURA COMPLETADA" : "LECTURA EN PROGRESO..."}
                        </button>
                      </div>
                    </div>
                  </div>
                )}
              </Dialog.Panel>
            </Transition.Child>
          </div>
        </div>
      </Dialog>
    </Transition.Root>
  );
}// src/components/test/CourseTestModal.tsx
