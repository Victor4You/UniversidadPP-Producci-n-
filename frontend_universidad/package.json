{
  "name": "universidad-puropollo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "electron-dev": "electron .",
    "start": "next start",
    "lint": "next lint",
    "app:dist": "next build && electron-builder"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.555.0",
    "next": "^16.0.9",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.68.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "8.17.0",
    "@typescript-eslint/parser": "8.17.0",
    "autoprefixer": "^10.4.22",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.26",
    "postcss": "^8.5.6",
    "prettier": "3.3.3",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3"
  },
  "build": {
    "appId": "com.universidad.puropollo",
    "productName": "Universidad Puro Pollo",
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "dist/**/*",
          "node_modules/**/*",
          "package.json"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
